# AegisCore Intelligence Platform — environment template (no secrets committed)

# Copy to .env and fill values locally / in your secret store.



# --- Runtime ---

APP_ENV=development

LOG_LEVEL=INFO

API_V1_PREFIX=/api/v1



# --- Backend (FastAPI) ---

PROJECT_NAME=AegisCore Intelligence API

BACKEND_HOST=0.0.0.0

BACKEND_PORT=8000

CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=INFO

LOG_JSON=false



# --- PostgreSQL (OLTP + reporting DBs can share cluster with separate databases) ---

POSTGRES_HOST=localhost

POSTGRES_PORT=5432

POSTGRES_USER=aegiscore

POSTGRES_PASSWORD=change-me

POSTGRES_DB=aegiscore_oltp

POSTGRES_REPORTING_DB=aegiscore_reporting



# Sync URL (Alembic, ETL, seeds — Phase 2+):

# DATABASE_URL=postgresql+psycopg://aegiscore:change-me@localhost:5432/aegiscore

# Phase 3 async API may use postgresql+asyncpg://... (see backend/requirements/async.txt)



# --- Redis ---

REDIS_URL=redis://localhost:6379/0



# --- JWT ---

JWT_SECRET_KEY=abcd1234abcd1234abcd1234abcd1234abcd1234abcd1234abcd1234abcd1234

JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30

REFRESH_TOKEN_EXPIRE_DAYS=14



# --- Frontend (Next.js public) ---

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000



# --- ML risk prioritization (Phase 4) ---

# Path to joblib bundle from `python -m ml.training.train_prioritizer ...`

ML_MODEL_PATH=ml/models/artifacts/risk_prioritization.joblib

ML_INFERENCE_ENABLED=true



# --- Prometheus metrics (Phase 8) — API only; keep off on public endpoints without auth ---

# PROMETHEUS_METRICS_ENABLED=false



# --- Power BI (Phase 6) — optional embed / automation ---

# Tenant and app registration (Azure AD) for REST or embed token flows:

# POWERBI_TENANT_ID=

# POWERBI_CLIENT_ID=

# POWERBI_CLIENT_SECRET=   # use secret store in production; never commit

# Target artifacts in the Power BI service:

# POWERBI_WORKSPACE_ID=

# POWERBI_REPORT_ID=

# POWERBI_DATASET_ID=      # optional, for refresh API calls

# Authority override (rare):

# POWERBI_AUTHORITY=https://login.microsoftonline.com/${POWERBI_TENANT_ID}



# --- Email Configuration ---
# Email provider: console (dev), smtp, or ses (AWS)
EMAIL_PROVIDER=console
FROM_EMAIL=noreply@aegiscore.io

# SMTP settings (used when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true

# AWS SES settings (used when EMAIL_PROVIDER=ses)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1



# --- Rate limiting ---

RATE_LIMIT_PER_MINUTE=120



# --- Secret Management (Phase 10) ---
# Secret provider: env (default), vault (HashiCorp Vault), aws_ssm (AWS Systems Manager)
# SECRET_PROVIDER=env
# SECRET_PROVIDER_PREFIX=SECRET_
# VAULT_ADDR=https://vault.example.com:8200



# --- GitHub Actions deploy smoke (Phase 9) — set in repo Environment secrets, not .env ---

# STAGING_PUBLIC_API_BASE_URL=https://api.staging.example.com

# PRODUCTION_PUBLIC_API_BASE_URL=https://api.example.com



# --- Docker Compose (Phase 7) — optional host port overrides ---
# Compose project name controls container/image prefixes.
COMPOSE_PROJECT_NAME=aegiscore-platform

# POSTGRES_PUBLISH_PORT=5432

# API_PUBLISH_PORT=8000

# WEB_PUBLISH_PORT=3000

# For shared or demo hosts, always set strong values (do not rely on compose defaults):

# POSTGRES_PASSWORD=

# JWT_SECRET_KEY=

